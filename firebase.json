{
  "firestore": {
    "database": "(default)",
    "location": "australia-southeast2",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
      "source": "functions"
    }
  ],
  "hosting": {
    "site": "youthealth",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/places/text", "function": { "functionId": "placesText", "region": "australia-southeast2" } },
      { "source": "/api/places/nearby", "function": { "functionId": "placesNearby", "region": "australia-southeast2" } },
      { "source": "/api/directions", "function": { "functionId": "directions", "region": "australia-southeast2" } },
      { "source": "/api/sendEmail", "function": { "functionId": "sendEmail", "region": "australia-southeast2" } },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
